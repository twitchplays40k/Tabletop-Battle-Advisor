{
  "notes": [
    "Optional customer-editable base/footprint lookup.",
    "Roster exports often do not include official base sizes. The app uses roster text first, then this file, then a heuristic.",
    "For vehicles without round bases, use footprint_mm as a practical circular footprint for spacing/clicking. Values are not official unless you verify them against the model/instructions you own.",
    "v33 also supports oval bases with base_length_mm/base_width_mm or oval_mm: [75, 42]."
  ],
  "rules": [
    {
      "match": [
        "example oval base"
      ],
      "base_length_mm": 75,
      "base_width_mm": 42,
      "source": "example schema only; edit/remove for your own collection"
    },
    {
      "match": [
        "angron",
        "bloodthirster",
        "avatar"
      ],
      "base_mm": 100,
      "source": "default large monster heuristic"
    },
